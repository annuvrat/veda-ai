# Environment
NODE_ENV=production

# Server
PORT=3000

# MongoDB Configuration
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=password123
MONGO_DB=ved
MONGO_PORT=27017

# Redis Configuration
